# macOS
.DS_Store

# Marcador de punto de montaje del wrapper (no es artefacto de este repo)
.keep

# Descargas/artefactos pesados (ISO, VMs, instaladores, cache de Packer, salidas de build): conservar la carpeta
/artifacts/*
!/artifacts/.gitkeep

# Configuración local con credenciales del orquestador
.env

# Registro de slots por worktree (estado local del orquestador wt-*)
/.worktrees/

# Autounattend generado a partir del template (contiene credenciales del guest)
/packer/Autounattend.xml

# Salida generada del generador de la golden slice: CREATE/loaders + CSV concatenados con DATOS DE PROD
# (se regenera con 'python3 goldenslice/generate.py'); NUNCA se versiona (leak de datos reales). build-wt<N> son
# los directorios de build POR SLOT (multi-golden en paralelo, req4).
/goldenslice/build/
/goldenslice/build-wt*/
