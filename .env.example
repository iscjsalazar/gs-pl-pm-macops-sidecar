# gs-pl-pm-macops-sidecar/.env.example — plantilla de variables (versionada). Hay DOS destinos:
#
#   [A] data tier + API (pm-*)  -> copiar a  gs-pl-pm-macops-sidecar/.env        (lo carga pm.sh/lib/common.sh en la M1)
#   [B] legado host-Windows (legacy-*) -> copiar a  ~/pm-host-windows/.env  EN macdata
#       (lo cargan los scripts de build/VM que corren ALLA por SSH: vm-up.sh, stage-app.sh, deploy-app.sh, ...)
#
# Casi todo tiene default razonable. Minimo a fijar: [A] PM_PROJECT unico por agente y, para intel, PM_REMOTE_SSH.
# Regla del legado: TODO lo descargado/pesado va bajo $ART (artifacts/), nada fuera de ese folder.

# =====================================================================
# [A] data tier + API (pm-*)  ->  gs-pl-pm-macops-sidecar/.env
# =====================================================================

# target de ejecucion
PM_TARGET=local                 # local | intel
PM_PROFILE=sql                  # sql | full (full = + Oracle + Service Bus emulador)

# aislamiento multi-stack (varios agentes en paralelo)
PM_PROJECT=pm-local             # UNICO por agente/solicitud (prefija contenedores/volumenes/red)
PM_PORT_MODE=offset             # offset | ephemeral
PM_PORT_OFFSET=0                # offset -> SQL=1433+OFF, Oracle=1521+OFF, bus=5672+OFF
PM_MAX_CONCURRENT_STACKS=2      # guard por CPU/RAM

# credenciales (rotar)
PM_SQL_SA_PASSWORD=Pm_Local_2026!
PM_ORACLE_PASSWORD=Pm_Oracle_2026!

# docker
PM_DOCKER_CONTEXT=colima        # contexto local (colima | desktop-linux)

# mac Intel (target=intel): rsync de containers/ + docker compose via SSH
PM_REMOTE_SSH=                   # alias/host SSH de la mac Intel (p.ej. macdata)
PM_REMOTE_DIR=pm-containers      # carpeta destino en la Intel (~/pm-containers)
PM_REMOTE_DOCKER_CONTEXT=        # contexto docker EN la Intel (p.ej. colima-pm-data); vacio = activo del remoto

# integration tests del backend: a que SQL apuntar (contenedores en macdata, asumidos arriba)
PM_TEST_SQL_HOST=127.0.0.1       # local; para target=intel, el alias macdata (mapeado en /etc/hosts del M1; ver README)
PM_PLANNING_DB=pm_planning       # BD de producto; la crean las migraciones EF (no el seeder)

# API real (verbos pm-api / pm-test): corre en ESTA mac (M1). Puerto unico de verdad (offset por agente).
PM_API_HOST=127.0.0.1
PM_API_PORT=                     # vacio -> 5180 + PM_PORT_OFFSET

# Backend en modo E2E (verbo pm e2e-backend, Opcion C): la API corre en SU PROPIO contenedor en macdata,
# unido a la red del data tier; el guest Windows (legado) la alcanza por la pasarela NAT. Requiere TARGET=intel + REMOTE=macdata.
PM_REMOTE_SOLUTION_DIR=pm-solution               # carpeta en macdata: contexto de build de la imagen de la API
PM_GUEST_GATEWAY=172.16.128.1                     # IP de macdata vista DESDE el guest (host del bridge/NAT)
PM_GUEST_WINHOST=172.16.128.129                   # IP NAT del guest Windows (= WINHOST del legado)
PM_GUEST_KEY=~/pm-host-windows/artifacts/ssh/id_pmwin   # llave SSH al guest (residente EN macdata; ~ se expande alla)
PM_E2E_DATATIER=1                                 # 1: e2e-backend levanta el data tier antes de la API; 0: lo asume arriba

# Service Bus emulador + proxy LN (aplican con PROFILE=full)
PM_LN_DB=erpln106                # BD del proxy LN sobre el mismo SQL; la consume la ACL real
PM_SERVICEBUS_HOST=              # vacio -> = PM_TEST_SQL_HOST (mismo host del data tier)
PM_SB_SA_PASSWORD=Sb_Local_2026! # password del SQL Edge del emulador
# PM_SB_HOST_PORT se deriva 5672 + PM_PORT_OFFSET (no se fija aqui)

# =====================================================================
# [B] legado host-Windows (legacy-*)  ->  ~/pm-host-windows/.env EN macdata
# =====================================================================

# --- Acceso a la macdata (Mac Intel) ---
MACDATA=usuario@macdata.local            # destino SSH de la macdata

# --- Folder exclusivo (en la macdata) ---
HW=~/pm-host-windows                     # checkout del flujo legado EN macdata (donde corren los scripts de build/VM)
ART=$HW/artifacts                        # raiz EXCLUSIVA de descargas/artefactos (gitignored)

# --- VM Windows ---
VMNAME=pm-win2022core
ISO=$ART/iso/Windows_Server_2022.iso     # ISO eval (sin product key) -> dejar aqui
VMX=$ART/vms/$VMNAME/$VMNAME.vmx
VM_CPUS=2
VM_RAM_MB=4096
VM_DISK_MB=40000
WINUSER=Administrator
WINPASS=                                  # generar; NO commitear (este archivo .env esta gitignored)

# --- App legada ---
APP_SRC=$ART/src/CargaPlantaPT_LN        # copia del legado (de pl-pm-legacy)
SITE_PORT_40=8040                         # sitio IIS legacy 4.0
SITE_PORT_48=8048                         # sitio IIS upgradeado 4.8 (paralelo, para comparar)

# --- Lanzamiento (consumido por vm-up.sh / stage-app.sh / deploy-app.sh, que corren EN macdata) ---
WINHOST=172.16.128.129                    # IP del guest Windows (NAT interna de macdata)
GUEST_KEY=$HOME/pm-host-windows/artifacts/ssh/id_pmwin   # llave SSH al guest (gitignored)
STAGE=$ART/stage                          # stage de la fuente del legado antes de empujarla al guest
SITE_PORT=8080                            # puerto IIS del legado en el guest (default de make legacy-launch)

# --- BD (delegadas a la solicitud db-setup-containers; solo conectividad) ---
COLIMA_HOST=                              # host/IP de Colima en la macdata (para Test-NetConnection 1521/1433)
